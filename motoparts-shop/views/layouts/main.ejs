<!doctype html>
<html lang="vi">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <title><%= title ? `${title} - ${(setting && setting.websiteName) || 'MotoParts Shop'}` : 'MotoParts Shop' %></title>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap" rel="stylesheet">
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
  <link rel="stylesheet" href="/css/style.css">
</head>
<body>
  <%- include('../partials/navbar') %>
  <main>
    <% if (success && success.length) { %>
      <div class="container pt-3"><div class="alert alert-success"><%= success[0] %></div></div>
    <% } %>
    <% if (error && error.length) { %>
      <div class="container pt-3"><div class="alert alert-danger"><%= error[0] %></div></div>
    <% } %>
    <%- body %>
  </main>
  <footer class="site-footer">
    <div class="container footer-inner">
      <div>
        <div class="footer-brand"><%= (setting && setting.logoText) || 'MotoParts' %></div>
        <div class="footer-copy">Phụ tùng xe máy, đồ chơi xe và dịch vụ tư vấn nhanh.</div>
      </div>
      <div class="footer-links">
        <% if (setting && setting.facebookLink) { %><a href="<%= setting.facebookLink %>" target="_blank" rel="noopener">Facebook</a><% } %>
        <% if (setting && setting.zaloLink) { %><a href="<%= setting.zaloLink %>" target="_blank" rel="noopener">Zalo</a><% } %>
        <% if (setting && setting.tiktokLink) { %><a href="<%= setting.tiktokLink %>" target="_blank" rel="noopener">TikTok</a><% } %>
        <% if (setting && setting.shopeeLink) { %><a href="<%= setting.shopeeLink %>" target="_blank" rel="noopener">Shopee</a><% } %>
      </div>
    </div>
  </footer>
  <script src="https://unpkg.com/lucide@latest/dist/umd/lucide.min.js"></script>
  <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
  <script src="/js/app.js"></script>
  <script>lucide.createIcons();</script>
</body>
</html>
