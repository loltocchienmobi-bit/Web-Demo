<section class="shop-hero">
  <div class="hero-orbit orbit-a"></div>
  <div class="hero-orbit orbit-b"></div>
  <div class="container hero-grid">
    <div class="hero-copy">
      <span class="eyebrow live-badge"><i data-lucide="sparkles"></i> Cửa hàng phụ tùng xe máy 4.0</span>
      <h1>Phụ tùng tốt, lên xe gọn, chốt đơn nhanh.</h1>
      <p>Quản lý sản phẩm, giá, tồn kho và liên hệ mua hàng trong một website gọn đẹp cho shop xe máy.</p>
      <form class="search-bar" method="GET" action="/">
        <i data-lucide="search"></i>
        <input type="search" name="q" placeholder="Tìm pô, ắc quy, lọc gió..." value="<%= q || '' %>">
        <button type="submit">Tìm kiếm</button>
      </form>
      <div class="hero-stats">
        <div><strong><%= totalProducts || 0 %></strong><span>Sản phẩm</span></div>
        <div><strong><%= featuredCount || 0 %></strong><span>Nổi bật</span></div>
        <div><strong><%= categories ? categories.length : 0 %></strong><span>Danh mục</span></div>
      </div>
    </div>
    <div class="hero-panel clean-hero-panel">
      <div class="scanner-line"></div>
      <img src="/images/hero-showroom.png" alt="Showroom phụ tùng MotoParts">
    </div>
  </div>
</section>

<section class="container section-block">
  <div class="section-heading">
    <div>
      <span class="eyebrow">Catalog</span>
      <h2><%= q ? `Kết quả cho "${q}"` : 'Sản phẩm mới nhất' %></h2>
    </div>
    <div class="category-pills">
      <% (categories || []).slice(0, 6).forEach(category => { %>
        <span><%= category %></span>
      <% }) %>
    </div>
  </div>

  <% if (!products || products.length === 0) { %>
    <div class="empty-state">
      <i data-lucide="package-search"></i>
      <h3>Chưa có sản phẩm phù hợp</h3>
      <p>Thử tìm bằng tên khác hoặc thêm sản phẩm mới trong trang admin.</p>
    </div>
  <% } %>

  <div class="product-grid">
    <% products.forEach(product => { %>
      <article class="product-card reveal-card">
        <a class="product-media" href="/product/<%= product._id %>">
          <% if (product.featured) { %><span class="badge-hot">Nổi bật</span><% } %>
          <img src="<%= product.image %>" alt="<%= product.name %>">
        </a>
        <div class="product-body">
          <div class="product-meta"><%= product.brand %> / <%= product.bikeModel %></div>
          <h3><a href="/product/<%= product._id %>"><%= product.name %></a></h3>
          <p><%= product.description %></p>
          <div class="product-bottom">
            <strong><%= product.price.toLocaleString('vi-VN') %> đ</strong>
            <a class="icon-button" href="/product/<%= product._id %>" aria-label="Xem chi tiết"><i data-lucide="arrow-right"></i></a>
          </div>
        </div>
      </article>
    <% }) %>
  </div>
</section>
